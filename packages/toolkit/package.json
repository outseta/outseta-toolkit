{
  "name": "@outseta/toolkit",
  "version": "0.8.0",
  "description": "Outseta's toolkit for visual website builders",
  "type": "module",
  "unpkg": "./dist/index.iife.js",
  "jsdelivr": "./dist/index.iife.js",
  "exports": {
    "./framer/overrides": {
      "import": "./dist/framer/overrides/index.js",
      "types": "./dist/framer/overrides/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "outseta",
    "toolkit",
    "framer",
    "overrides"
  ],
  "author": "Outseta",
  "license": "MIT",
  "dependencies": {
    "@outseta/react": "workspace:*",
    "@outseta/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.3.6",
    "typescript": "^5.0.0"
  }
}
